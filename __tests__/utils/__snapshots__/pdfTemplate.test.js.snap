                            <th style="border: 1px solid #ddd; padding: 8px;">Unidade</th>
                            <th style="border: 1px solid #ddd; padding: 8px;">Água consumida (L)</th>
                            <th style="border: 1px solid #ddd; padding: 8px;">Km final</th>
                            <th style="border: 1px solid #ddd; padding: 8px;">Motorista</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td style="border: 1px solid #ddd; padding: 8px;">UCIR-0331</td>
                            <td style="border: 1px solid #ddd; padding: 8px;">Centro</td>
                            <td style="border: 1px solid #ddd; padding: 8px;">500</td>
                            <td style="border: 1px solid #ddd; padding: 8px;">1200</td>
                            <td style="border: 1px solid #ddd; padding: 8px;">Pedro</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="details-container">
                <div class="details-title">Serviços de apoio</div>
                <table style="width: 100%; border-collapse: collapse; margin-bottom: 20px;">
                    <thead>
                        <tr>
                            <th style="border: 1px solid #ddd; padding: 8px;">VTR</th>
                            <th style="border: 1px solid #ddd; padding: 8px;">Cidade</th>
                            <th style="border: 1px solid #ddd; padding: 8px;">Água consumida (L)</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td style="border: 1px solid #ddd; padding: 8px;">UTB-0305</td>
                            <td style="border: 1px solid #ddd; padding: 8px;">Guaramirim</td>
                            <td style="border: 1px solid #ddd; padding: 8px;">200</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="details-container">
                <div class="details-row">
                    <div><span class="details-label">Total de água consumida (L): </span> 700</div>
                </div>
            </div>

            <div class="details-container">
                <div class="details-title">Guarnição</div>
                <table style="width: 100%; border-collapse: collapse; margin-bottom: 20px;">
                    <thead>
                        <tr>
                            <th style="border: 1px solid #ddd; padding: 8px;">Nome</th>
                            <th style="border: 1px solid #ddd; padding: 8px;">VTR</th>
                            <th style="border: 1px solid #ddd; padding: 8px;">Combatente</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td style="border: 1px solid #ddd; padding: 8px;">João</td>
                            <td style="border: 1px solid #ddd; padding: 8px;">UCIR-0331</td>
                            <td style="border: 1px solid #ddd; padding: 8px;">Sim</td>
                        </tr>
                        <tr>
                            <td style="border: 1px solid #ddd; padding: 8px;">Maria</td>
                            <td style="border: 1px solid #ddd; padding: 8px;">UCIR-0331</td>
                            <td style="border: 1px solid #ddd; padding: 8px;">Não</td>

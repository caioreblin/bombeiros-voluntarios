                        <div><span class="details-label">Não Edificada:</span> 20 m²</div>
                        <div><span class="details-label">Tipo de perda:</span> Parcial</div>
                    </div>
                    <div>
                        <div><span class="details-label">Área total</span></div>
                        <div><span class="details-label">Terreno:</span> 300 m²</div>

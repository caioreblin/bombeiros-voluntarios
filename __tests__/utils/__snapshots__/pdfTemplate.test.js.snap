                </div>
            </div>

            <div class="details-container">
                <div class="details-title">Vazamento de produto perigoso</div>
                <div class="details-row">
                    <div style="width: 100%;">
                        <div><span class="details-label">Houve vazamento:</span> Não</div>
                        <div><span class="details-label">Nome do produto:</span> N/A</div>
                        <div><span class="details-label">OBS:</span> N/A</div>
                    </div>
                </div>
            </div>

            <div class="details-container">
                <div class="details-title">Vazamento de Gás</div>
                <div class="details-row">
                    <div style="width: 100%;">
                        <div><span class="details-label">Houve vazamento:</span> Sim</div>
                        <div><span class="details-label">Tipo de gás:</span> G.L.P.</div>
                        <div><span class="details-label">OBS:</span> Cheiro forte no local</div>
                    </div>
                </div>

            <div class="details-container">
                <div class="details-title">Sistema de prevenção existentes</div>
                <div class="details-row">
                    <div><span class="details-label">SPE - Extintores:</span> Sim</div>
                    <div><span class="details-label">EE - Elevador de emergência:</span> Não</div>
                </div>
                <div class="details-row">
                    <div><span class="details-label">SHP - Hidrantes:</span> Não</div>
                    <div><span class="details-label">Exaustão de fumaça:</span> Não</div>
                </div>
                <div class="details-row">
                    <div><span class="details-label">SIE - Iluminação de emergência:</span> Não</div>
                    <div><span class="details-label">Ventilação permanente (GLP):</span> Não</div>
                </div>
                <div class="details-row">
                    <div><span class="details-label">SADI - Alarme:</span> Sim</div>
                    <div><span class="details-label">Compartimentação:</span> Sim</div>
                </div>
                <div class="details-row">
                    <div><span class="details-label">SPK - Sprinkler:</span> Não</div>
                    <div><span class="details-label">Acesso de viaturas:</span> Sim</div>
                </div>
                <div class="details-row">
                    <div><span class="details-label">Sinalização p/ abandono:</span> Sim</div>
                </div>
            </div>

            <div class="details-container">
                <div class="details-row">
                    <div><span class="details-label">Usado extintor: </span> Sim</div>
                    <div><span class="details-label">Quantos:</span> 2</div>
                    <div><span class="details-label">Tipo:</span> P.Q.S</div>
                    <div><span class="details-label">Da onde:</span> Edificação</div>
                    
                </div>
            </div>

            <div class="details-container">
                <div class="details-title">Tabela de viaturas</div>
                <table style="width: 100%; border-collapse: collapse; margin-bottom: 20px;">
                    <thead>

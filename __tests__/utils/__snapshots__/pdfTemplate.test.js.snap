// Jest Snapshot v1, https://goo.gl/fbAQLP

exports[`buildReportHtml matches the snapshot for a filled report 1`] = `
"
        <html>
        <head>
            <meta charset="UTF-8">
            <style>
                .section-container {
                    display: flex;
                    justify-content: space-between;
                    align-items: center;
                    border: 1px solid black;
                    padding: 10px;
                    border-radius: 10px;
                    font-family: Arial, sans-serif;
                }

                .logo-container img {
                    width: 80px;
                    height: auto;
                }

                .info-container {
                    text-align: center;
                    font-family: Arial, sans-serif;
                }

                .details-container {
                    font-family: Arial, sans-serif;
                    border: 1px solid black;
                    border-radius: 10px;
                    padding: 10px;
                    margin-top: 10px;
                }

                .details-row {
                    display: flex;
                    justify-content: space-between;
                }

                .details-row div {
                    margin: 5px 0;
                    width: 50%;
                    text-align: left;
                }

                .details-label {
                    font-weight: bold;
                }

                .details-title {
                    font-weight: normal;
                    margin-bottom: 10px;
                }

                td, th {
                    text-align: center;
                }
            </style>
        </head>

        <body>
            <div class="section-container">
                <div class="logo-container">
                    <img src="data:image/png;base64,SAMPLELOGO" alt="Logo dos Bombeiros Voluntários">
                </div>

                <div class="info-container">
                    <strong>Associação de Serviços Sociais Voluntários de Jaraguá do Sul</strong>
                    <br>
                    <strong>Bombeiros Voluntários</strong>
                </div>

                <div class="details-container" style="margin-top: 0px;">
                    <div>Data: <strong>01/02/2024</strong></div>
                    <div>Hora: <strong>14:30</strong></div>
                    <div>Equipe: <strong>Alfa</strong></div>
                    <div>Código de IR: <strong>2</strong></div>
                    <div>Nº do B.O: <strong>987</strong></div>
                </div>
            </div>

            <div class="details-container">
                <div class="details-row">
                    <div><span class="details-label">Nome do Proprietário:</span> Ana Silva</div>
                    <div><span class="details-label">CPF:</span> 12345678900</div>
                </div>
                <div class="details-row">
                    <div><span class="details-label">Endereço:</span> Rua das Flores</div>
                    <div><span class="details-label">Bairro:</span> Centro</div>
                </div>
                <div class="details-row">
                    <div><span class="details-label">Número:</span> 100</div>
                    <div><span class="details-label">Fone:</span> 4799990000</div>
                </div>
                <div class="details-row">
                    <div><span class="details-label">Responsável pelo imóvel:</span> Proprietário</div>
                    <div><span class="details-label">Empresa:</span> Não</div>
